<file path="k8s/platform/oauth2-proxy/ingress.yaml">
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: oauth2-proxy
  namespace: oauth2-proxy
  annotations:
    cert-manager.io/cluster-issuer: local-root-ca
    cert-manager.io/duration: 168h
    cert-manager.io/renew-before: 24h
    # --- ADD THESE TO FIX THE 502 ---
    nginx.ingress.kubernetes.io/proxy-buffer-size: "16k"
    nginx.ingress.kubernetes.io/proxy-buffers-number: "8"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "32k"
    # --------------------------------

spec:
  ingressClassName: nginx

  tls:
    - hosts:
        - auth.local
      secretName: auth-tls

  rules:
    - host: auth.local
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: oauth2-proxy
                port:
                  number: 80
</file>

<file path="k8s/platform/oauth2-proxy/values.yaml">
config:
  clientID: "oauth2-proxy"
  existingSecret: "oauth2-proxy-secrets"

extraArgs:
  provider: oidc
  oidc-issuer-url: https://keycloak.local/realms/zero-trust-local-platform
  ssl-insecure-skip-verify: "true"
  redirect-url: https://auth.local/oauth2/callback
  email-domain: "*"
  cookie-secure: "true"
  cookie-samesite: "lax"
  skip-provider-button: "true"
  insecure-oidc-skip-issuer-verification: "true"

hostAliases:
  - ip: "192.168.65.240"
    hostnames:
      - "keycloak.local"

service:
  type: ClusterIP

ingress:
  enabled: false   # IMPORTANT: we are managing ingress manually
</file>

